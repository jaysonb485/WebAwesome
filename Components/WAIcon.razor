@inherits WAComponentBase

@if (!string.IsNullOrWhiteSpace(Tooltip))
{
    <wa-tooltip for="@Id">@Tooltip</wa-tooltip>
}
<wa-icon @ref="@Element"
         id="@Id"
         @attributes="@GetAttributesWithIcon()"
         style="@StyleNames"
         class="@ClassNames"
         slot="@Slot"></wa-icon>

