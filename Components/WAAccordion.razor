@inherits WAComponentBase
<wa-accordion @ref="@Element"
         id="@Id"
         @attributes="@AdditionalAttributes"
         style="@StyleNames"
         class="@ClassNames"
         slot="@Slot"
         heading-level="@HeadingLevelString"
         appearance="@AppearanceString"
         mode="@ModeString"
         icon-placement="@IconPlacementString"
         >
    @ChildContent
</wa-accordion>

