@inherits WAComponentBase
<wa-avatar @ref="@Element"
           id="@Id"
           @attributes="@AdditionalAttributes"
           slot="@Slot"
           label="@Label"
           image="@ImageSource"
           initials="@Initials"
           style="@StyleNames"
           class="@ClassNames"
           loading="@Loading"
           shape="@ShapeString">

    @if (Icon != null || !String.IsNullOrWhiteSpace(IconName))
    {
        <WAIcon Icon="@Icon" IconName="@IconName" Slot="icon"></WAIcon>
    }
</wa-avatar>
