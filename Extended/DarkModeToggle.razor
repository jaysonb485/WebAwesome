@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

@code {

    public async Task SetDarkModeAsync(bool DarkMode)
    {
        var path = "./_content/WebAwesomeBlazor/Extended/DarkModeToggle.razor.js";
        var _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", path);
        await _module.InvokeVoidAsync("setDarkMode", DarkMode);
    }

    public void SetDarkMode(bool DarkMode) => _ = SetDarkModeAsync(DarkMode);

}
